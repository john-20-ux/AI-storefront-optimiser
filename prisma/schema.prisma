// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// --- AI Storefront Optimizer: minimal data only (no raw catalog/customer/order data) ---

model Shop {
  id            String   @id @default(cuid())
  shopDomain    String   @unique
  installedAt   DateTime @default(now())
  planName      String   @default("free")
  billingStatus String   @default("none")
}

model ScanSettings {
  shopDomain        String   @id
  enabledChecks     Json     @default("{\"seo\":true,\"altText\":true,\"description\":true,\"category\":true,\"tags\":true,\"variants\":true}")
  tonePreference    String   @default("simple")
  targetAudience    String   @default("general")
  aiRule            String   @default("balanced")
  autoFixEnabled    Boolean  @default(false)
  ignoredProductIds Json?
  updatedAt         DateTime @updatedAt
}

model ScanSummary {
  shopDomain           String    @id
  lastScanAt           DateTime?
  totalProductsScanned Int       @default(0)
  averageScore         Int       @default(0)
  issueCounts          Json      @default("{}")
}

// Each shop connects its own AI provider. The API key is encrypted at rest
// (AES-256-GCM) and never returned to the client.
model AiConnection {
  shopDomain   String   @id
  provider     String // anthropic | openai | openrouter
  encryptedKey String
  model        String? // optional model override
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Short-lived PKCE state for the OpenRouter OAuth handshake.
model OAuthState {
  state        String   @id
  shopDomain   String
  codeVerifier String
  createdAt    DateTime @default(now())
}
